# Standalone OpenHarness Web frontend deployment.
# Nginx serves static assets and proxies /api plus WebSocket traffic to the backend container.

TEST_WEB_PORT=5173
OPENHARNESS_BACKEND_NETWORK=openharness-dev_default
OPENHARNESS_BACKEND_UPSTREAM=http://openharness-dev:8787
CLIENT_MAX_BODY_SIZE=100m

# Keep this empty so frontend calls /api on the same origin and avoids browser CORS/cookie issues.
VITE_OPENHARNESS_API_BASE=

# Override only if the default mirror is unavailable.
TEST_WEB_NODE_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/node:20-bookworm-slim
TEST_WEB_NGINX_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/nginx:1.27
